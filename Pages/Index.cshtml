@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome";
}

<style>
    /* Hero Section specific styles */
    .cs-hero-section {
        position: relative;
        text-align: center;
        padding: 5rem 2rem;
        border-radius: var(--cs-radius-xl);
        overflow: hidden;
        margin-bottom: 4rem;
        background: radial-gradient(circle at top, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
        border: 1px solid var(--cs-border);
    }
    
    .cs-hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url('/images/grid.svg') center/cover;
        opacity: 0.05;
        pointer-events: none;
    }

    .cs-hero-title {
        font-size: 3.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #F0F4FF 0%, #8B95A8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .cs-hero-subtitle {
        font-size: 1.25rem;
        color: var(--cs-text-secondary);
        max-width: 600px;
        margin: 0 auto 2.5rem;
        line-height: 1.6;
    }

    .cs-hero-cta {
        display: flex;
        justify-content: center;
        gap: 1.25rem;
        position: relative;
        z-index: 2;
    }

    /* Mockup Showcase */
    .cs-mockup-wrapper {
        perspective: 1200px;
        margin: -2rem auto 4rem;
        max-width: 900px;
        padding: 0 1rem;
    }
    
    .cs-mockup-image {
        width: 100%;
        border-radius: var(--cs-radius-lg);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 40px rgba(0, 201, 167, 0.15);
        border: 1px solid var(--cs-border-accent);
        transform: rotateX(8deg) scale(0.95);
        transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.6s ease;
    }

    .cs-mockup-wrapper:hover .cs-mockup-image {
        transform: rotateX(0deg) scale(1);
        box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.6), 0 0 60px rgba(0, 201, 167, 0.25);
    }

    /* Features Grid */
    .cs-features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 4rem;
    }

    .cs-feature-card {
        padding: 2rem;
        text-align: left;
    }

    .cs-feature-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--cs-radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 1.5rem;
    }

    .cs-feature-card:hover .cs-feature-icon {
        transform: scale(1.1);
        transition: transform 0.3s var(--cs-ease-spring);
    }
</style>

<div class="cs-animate">
    <!-- Hero Section -->
    <div class="cs-hero-section cs-card">
        <img src="~/images/logo.png" alt="Logo" style="height: 120px; width: auto; margin-bottom: 2rem; display: block; margin-left: auto; margin-right: auto;" onerror="this.style.display='none';" />
        <h1 class="cs-hero-title">Intelligent Campus Security.</h1>
        <p class="cs-hero-subtitle">
            Experience real-time monitoring, rapid QR authentication, and instant incident response, all powered by our modern SaaS command center.
        </p>
        <div class="cs-hero-cta">
            <a asp-page="/Auth/Login" class="cs-btn cs-btn-primary" style="padding: 12px 28px; font-size: 15px;">
                <i class="ti ti-login"></i> Access Command Center
            </a>
            <a asp-page="/Scan" class="cs-btn cs-btn-secondary" style="padding: 12px 28px; font-size: 15px;">
                <i class="ti ti-qrcode"></i> Open Live Scanner
            </a>
        </div>
    </div>

    <!-- 3D Mockup Showcase -->
    <div class="cs-mockup-wrapper cs-animate" style="animation-delay: 200ms;">
        <img src="~/images/mockup.png" alt="Dashboard Interface Mockup" class="cs-mockup-image" />
    </div>

    <!-- Features Grid -->
    <div class="cs-features-grid cs-animate-stagger">
        
        <div class="cs-card cs-feature-card">
            <div class="cs-feature-icon" style="background: var(--cs-info-bg); color: var(--cs-info); border: 1px solid rgba(59, 130, 246, 0.2);">
                <i class="ti ti-chart-pie-filled"></i>
            </div>
            <h3 style="margin-top: 0; color: var(--cs-text-primary); font-size: 1.25rem;">Real-time Analytics</h3>
            <p style="color: var(--cs-text-muted); margin-bottom: 0;">
                Monitor campus occupancy, visitor logs, and guard schedules instantaneously through a high-performance interactive dashboard.
            </p>
        </div>

        <div class="cs-card cs-feature-card">
            <div class="cs-feature-icon" style="background: var(--cs-success-bg); color: var(--cs-success); border: 1px solid rgba(34, 197, 94, 0.2);">
                <i class="ti ti-scan"></i>
            </div>
            <h3 style="margin-top: 0; color: var(--cs-text-primary); font-size: 1.25rem;">Rapid QR Access</h3>
            <p style="color: var(--cs-text-muted); margin-bottom: 0;">
                Authenticate students and staff in milliseconds. Issue temporary visitor passes with automatic expiration controls.
            </p>
        </div>

        <div class="cs-card cs-feature-card">
            <div class="cs-feature-icon" style="background: var(--cs-danger-bg); color: var(--cs-danger); border: 1px solid rgba(239, 68, 68, 0.2);">
                <i class="ti ti-shield-exclamation"></i>
            </div>
            <h3 style="margin-top: 0; color: var(--cs-text-primary); font-size: 1.25rem;">Incident Reporting</h3>
            <p style="color: var(--cs-text-muted); margin-bottom: 0;">
                Log security incidents swiftly with attached visual evidence. Track resolution status and filter by critical severities.
            </p>
        </div>

    </div>
</div>

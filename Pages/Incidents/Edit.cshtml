@page "{id:int}"
@model CampusSentinel.Pages.Incidents.EditModel
@using CampusSentinel.Models

@{
    ViewData["Title"] = "Edit Incident";
}

<div class="cs-animate" style="max-width: 700px; margin: 0 auto;">
    
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 1.6rem; font-weight: 700; color: var(--cs-text-primary); margin: 0 0 0.25rem;">
                <i class="ti ti-edit" style="color: var(--cs-accent); margin-right: 0.4rem;"></i> Edit Incident #@Model.Input.Id.ToString("D4")
            </h1>
            <p style="color: var(--cs-text-muted); margin: 0; font-size: 0.875rem;">Modify incident parameters, location, severity, or current resolution status.</p>
        </div>
        <a asp-page="./Detail" asp-route-id="@Model.Input.Id" class="cs-btn cs-btn-secondary">
            <i class="ti ti-arrow-left"></i> Back to Detail
        </a>
    </div>

    <!-- Validation errors -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div style="background: var(--cs-danger-bg); border-left: 3px solid var(--cs-danger); border-radius: var(--cs-radius-sm); padding: 0.875rem 1rem; margin-bottom: 1.5rem; display: flex; gap: 0.5rem; align-items: flex-start;">
            <i class="ti ti-alert-triangle" style="color: var(--cs-danger); margin-top: 1px; flex-shrink: 0;"></i>
            <div asp-validation-summary="All" style="color: var(--cs-danger); font-size: 0.875rem;"></div>
        </div>
    }

    <!-- Form card -->
    <div class="cs-card">
        <div class="cs-card-header">
            <span class="cs-card-title"><i class="ti ti-clipboard-list" style="margin-right: 6px;"></i> Edit Incident Parameters</span>
            <span style="font-size: 0.78rem; color: var(--cs-text-muted);">Modify fields as necessary</span>
        </div>

        <form method="post" style="padding-top: 0.5rem;">
            <input type="hidden" asp-for="Input.Id" />

            <!-- Title -->
            <div class="cs-form-group">
                <label asp-for="Input.Title" class="cs-label">
                    <i class="ti ti-type" style="font-size: 12px; margin-right: 2px;"></i> Incident Title *
                </label>
                <input asp-for="Input.Title" class="cs-input" />
                <span asp-validation-for="Input.Title" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
            </div>

            <!-- Description -->
            <div class="cs-form-group">
                <label asp-for="Input.Description" class="cs-label">
                    <i class="ti ti-align-left" style="font-size: 12px; margin-right: 2px;"></i> Detailed Description *
                </label>
                <textarea asp-for="Input.Description" class="cs-textarea" rows="5"></textarea>
                <span asp-validation-for="Input.Description" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
            </div>

            <!-- Severity, Status & Location Grid -->
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Input.Severity" class="cs-label">
                        <i class="ti ti-shield-alert" style="font-size: 12px; margin-right: 2px;"></i> Severity Level *
                    </label>
                    <select asp-for="Input.Severity" class="cs-select" asp-items="Html.GetEnumSelectList<IncidentSeverity>()"></select>
                    <span asp-validation-for="Input.Severity" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>

                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Input.Status" class="cs-label">
                        <i class="ti ti-circle-check" style="font-size: 12px; margin-right: 2px;"></i> Status *
                    </label>
                    <select asp-for="Input.Status" class="cs-select" asp-items="Html.GetEnumSelectList<IncidentStatus>()"></select>
                    <span asp-validation-for="Input.Status" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>

                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Input.Location" class="cs-label">
                        <i class="ti ti-map-pin" style="font-size: 12px; margin-right: 2px;"></i> Location *
                    </label>
                    <input asp-for="Input.Location" class="cs-input" list="campusZones" />
                    <datalist id="campusZones">
                        <option value="Main Gate"></option>
                        <option value="Gate A"></option>
                        <option value="Gate B"></option>
                        <option value="Library Block"></option>
                        <option value="Cafeteria"></option>
                        <option value="Hostel Area"></option>
                        <option value="Admin Block"></option>
                    </datalist>
                    <span asp-validation-for="Input.Location" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>
            </div>

            <!-- Form Actions -->
            <div style="display: flex; gap: 0.75rem; border-top: 1px solid var(--cs-border); padding-top: 1.25rem; margin-top: 1.5rem;">
                <button type="submit" class="cs-btn cs-btn-primary" style="flex: 1; justify-content: center;">
                    <i class="ti ti-device-floppy"></i> Save Changes
                </button>
                <a asp-page="./Detail" asp-route-id="@Model.Input.Id" class="cs-btn cs-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

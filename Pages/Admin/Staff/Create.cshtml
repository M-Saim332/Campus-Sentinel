@page
@model CampusSentinel.Pages.Admin.Staff.CreateModel
@{
    ViewData["Title"] = "Add Staff Member";
}

<div class="cs-animate" style="max-width: 820px; margin: 0 auto;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 1.6rem; font-weight: 700; color: var(--cs-text-primary); margin: 0 0 0.25rem;">
                <i class="ti ti-id-badge" style="color: var(--cs-accent); margin-right: 0.4rem;"></i> Add New Staff Member
            </h1>
            <p style="color: var(--cs-text-muted); margin: 0; font-size: 0.875rem;">Register a new staff member and generate their QR access credential.</p>
        </div>
        <a asp-page="./Index" class="cs-btn cs-btn-secondary">
            <i class="ti ti-arrow-left"></i> Back to List
        </a>
    </div>

    <!-- Success card after creation -->
    @if (Model.GeneratedStaffId != null)
    {
        <div class="cs-card cs-animate" style="margin-bottom: 1.5rem; border-color: var(--cs-border-accent); text-align: center; padding: 2.5rem;">
            <div style="width: 56px; height: 56px; background: var(--cs-accent-glow); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
                <i class="ti ti-check" style="font-size: 1.8rem; color: var(--cs-accent);"></i>
            </div>
            <h3 style="color: var(--cs-accent); margin: 0 0 0.5rem;">Staff Registered Successfully!</h3>
            <p style="color: var(--cs-text-secondary); margin: 0 0 1.5rem;">
                Staff ID: <code style="background: var(--cs-bg-overlay); padding: 3px 10px; border-radius: 6px; font-family: var(--cs-font-mono); color: var(--cs-text-primary);">@Model.GeneratedStaffId</code>
            </p>

            <div style="display: inline-block; background: #fff; padding: 12px; border-radius: 12px; margin-bottom: 1.5rem; box-shadow: var(--cs-shadow-md);">
                <img src="data:image/png;base64,@Model.GeneratedQrCodeBase64"
                     id="finalQrImg" alt="QR Code"
                     style="width: 200px; height: 200px; display: block;" />
            </div>

            <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
                <a asp-page="./Create" class="cs-btn cs-btn-secondary">
                    <i class="ti ti-plus"></i> Add Another
                </a>
            </div>
        </div>
    }

    <!-- Form card -->
    <div class="cs-card">
        <div class="cs-card-header">
            <span class="cs-card-title"><i class="ti ti-forms" style="margin-right: 6px;"></i>Staff Information</span>
        </div>

        <form method="post" style="padding-top: 0.5rem;">

            <!-- Category -->
            <div class="cs-form-group">
                <label asp-for="Staff.Category" class="cs-label"></label>
                <select asp-for="Staff.Category" class="cs-select"
                        asp-items="Html.GetEnumSelectList<CampusSentinel.Models.StaffCategory>()">
                </select>
            </div>

            <!-- Full Name -->
            <div class="cs-form-group">
                <label asp-for="Staff.FullName" class="cs-label"></label>
                <input asp-for="Staff.FullName" class="cs-input" placeholder="e.g. Dr. Ahmed Ali" />
                <span asp-validation-for="Staff.FullName" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
            </div>

            <!-- Row: Designation + Dept/Uni -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Staff.Designation" class="cs-label"></label>
                    <input asp-for="Staff.Designation" class="cs-input" placeholder="e.g. Assistant Professor" />
                    <span asp-validation-for="Staff.Designation" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Staff.DepartmentOrUni" class="cs-label"></label>
                    <input asp-for="Staff.DepartmentOrUni" class="cs-input" placeholder="e.g. IDS, CS, UET" />
                    <span asp-validation-for="Staff.DepartmentOrUni" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>
            </div>

            <!-- Row: Gender + Phone -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Staff.Gender" class="cs-label"></label>
                    <select asp-for="Staff.Gender" class="cs-select">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                </div>
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Staff.PhoneNumber" class="cs-label"></label>
                    <input asp-for="Staff.PhoneNumber" class="cs-input" placeholder="+92 3XX XXXXXXX" />
                </div>
            </div>

            <!-- Staff ID Preview -->
            <div style="background: var(--cs-bg-elevated); border: 1px dashed var(--cs-border-accent); border-radius: var(--cs-radius-md); padding: 1rem 1.5rem; text-align: center; margin-bottom: 1.5rem;">
                <div style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--cs-text-muted); margin-bottom: 0.3rem;">
                    <i class="ti ti-id-badge-2"></i> Auto-generated Staff ID
                </div>
                <div style="font-family: var(--cs-font-mono); font-size: 1rem; color: var(--cs-text-secondary);">
                    Will be generated upon submission (e.g. <span style="color: var(--cs-accent);">FR-001-IDS</span>)
                </div>
            </div>

            <!-- Actions -->
            <div style="display: flex; gap: 0.75rem;">
                <button type="submit" class="cs-btn cs-btn-primary" style="flex: 1; justify-content: center;">
                    <i class="ti ti-qrcode"></i> Register Staff & Generate QR
                </button>
                <a asp-page="./Index" class="cs-btn cs-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<canvas id="conversionCanvas" style="display:none;"></canvas>

@section Scripts {
    <script>
        function downloadPng() {
            const link    = document.createElement('a');
            link.href     = "data:image/png;base64,@Model.GeneratedQrCodeBase64";
            link.download = 'QR_@(Model.GeneratedStaffId).png';
            link.click();
        }
        function downloadJpg() {
            const imgEl  = document.getElementById('finalQrImg');
            const canvas = document.getElementById('conversionCanvas');
            canvas.width = 400; canvas.height = 400;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#FFFFFF';
            ctx.fillRect(0, 0, 400, 400);
            ctx.drawImage(imgEl, 0, 0, 400, 400);
            const link    = document.createElement('a');
            link.href     = canvas.toDataURL('image/jpeg', 0.9);
            link.download = 'QR_@(Model.GeneratedStaffId).jpg';
            link.click();
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}

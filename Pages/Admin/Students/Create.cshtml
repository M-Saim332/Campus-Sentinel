@page
@model CampusSentinel.Pages.Admin.Students.CreateModel
@{
    ViewData["Title"] = "Add Student";
}

<div class="cs-animate" style="max-width: 820px; margin: 0 auto;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 1.6rem; font-weight: 700; color: var(--cs-text-primary); margin: 0 0 0.25rem;">
                <i class="ti ti-school" style="color: var(--cs-accent); margin-right: 0.4rem;"></i> Add New Student
            </h1>
            <p style="color: var(--cs-text-muted); margin: 0; font-size: 0.875rem;">Fill in student details to generate a unique QR code identity.</p>
        </div>
        <a asp-page="./Index" class="cs-btn cs-btn-secondary">
            <i class="ti ti-arrow-left"></i> Back to List
        </a>
    </div>

    <!-- Success card after creation -->
    @if (Model.GeneratedBarcodeId != null)
    {
        <div class="cs-card cs-animate" style="margin-bottom: 1.5rem; border-color: var(--cs-border-accent); text-align: center; padding: 2.5rem;">
            <div style="width: 56px; height: 56px; background: var(--cs-accent-glow); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
                <i class="ti ti-check" style="font-size: 1.8rem; color: var(--cs-accent);"></i>
            </div>
            <h3 style="color: var(--cs-accent); margin: 0 0 0.5rem;">Student Created Successfully!</h3>
            <p style="color: var(--cs-text-secondary); margin: 0 0 1.5rem;">
                QR Code ID: <code style="background: var(--cs-bg-overlay); padding: 3px 10px; border-radius: 6px; font-family: var(--cs-font-mono); color: var(--cs-text-primary);">@Model.GeneratedBarcodeId</code>
            </p>

            <div style="display: inline-block; background: #fff; padding: 12px; border-radius: 12px; margin-bottom: 1.5rem; box-shadow: var(--cs-shadow-md);">
                <img src="data:image/png;base64,@Model.GeneratedQrCodeBase64"
                     id="finalQrImg" alt="QR Code"
                     style="width: 200px; height: 200px; display: block;" />
            </div>

            <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
                <button type="button" onclick="downloadResultAsPng()" class="cs-btn cs-btn-primary">
                    <i class="ti ti-download"></i> Download PNG
                </button>
                <button type="button" onclick="downloadResultAsJpg()" class="cs-btn cs-btn-secondary">
                    <i class="ti ti-file-type-jpg"></i> Download JPEG
                </button>
                <a asp-page="./Create" class="cs-btn cs-btn-secondary">
                    <i class="ti ti-plus"></i> Add Another
                </a>
            </div>
        </div>
    }

    <!-- Form card -->
    <div class="cs-card">
        <div class="cs-card-header">
            <span class="cs-card-title"><i class="ti ti-forms" style="margin-right: 6px;"></i>Student Information</span>
        </div>

        <form method="post" style="padding-top: 0.5rem;">

            <!-- Row 1: Session + Department -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Student.Session" class="cs-label"></label>
                    <input asp-for="Student.Session" class="cs-input" id="sessionInput" placeholder="e.g. 2025" />
                    <span asp-validation-for="Student.Session" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Student.Department" class="cs-label"></label>
                    <input asp-for="Student.Department" class="cs-input" id="deptInput" placeholder="e.g. CS, DS, EE" />
                    <span asp-validation-for="Student.Department" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
                </div>
            </div>

            <!-- Full Name -->
            <div class="cs-form-group">
                <label asp-for="Student.FullName" class="cs-label"></label>
                <input asp-for="Student.FullName" class="cs-input" placeholder="e.g. Ali Hassan" />
                <span asp-validation-for="Student.FullName" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
            </div>

            <!-- Row 2: Gender + Residency -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Student.Gender" class="cs-label"></label>
                    <select asp-for="Student.Gender" class="cs-select">
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="cs-form-group" style="margin-bottom: 0;">
                    <label asp-for="Student.ResidencyType" class="cs-label"></label>
                    <select asp-for="Student.ResidencyType" class="cs-select">
                        <option value="Day Scholar">Day Scholar</option>
                        <option value="Hostelite">Hostelite</option>
                    </select>
                </div>
            </div>

            <!-- Registration No -->
            <div class="cs-form-group">
                <label asp-for="Student.RegistrationNo" class="cs-label"></label>
                <input asp-for="Student.RegistrationNo" class="cs-input" id="regInput" placeholder="e.g. 129" />
                <span asp-validation-for="Student.RegistrationNo" style="color: var(--cs-danger); font-size: 0.8rem;"></span>
            </div>

            <!-- Live QR ID Preview -->
            <div style="background: var(--cs-bg-elevated); border: 1px dashed var(--cs-border-accent); border-radius: var(--cs-radius-md); padding: 1rem 1.5rem; text-align: center; margin-bottom: 1.5rem;">
                <div style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--cs-text-muted); margin-bottom: 0.3rem;">
                    <i class="ti ti-qrcode"></i> QR Code ID Preview
                </div>
                <div id="barcodePreview" style="font-family: var(--cs-font-mono); font-size: 1.4rem; font-weight: 600; color: var(--cs-accent); letter-spacing: 0.12em;">
                    0000-XX-000
                </div>
            </div>

            <!-- Actions -->
            <div style="display: flex; gap: 0.75rem;">
                <button type="submit" class="cs-btn cs-btn-primary" style="flex: 1; justify-content: center;">
                    <i class="ti ti-qrcode"></i> Add Student & Generate QR
                </button>
                <a asp-page="./Index" class="cs-btn cs-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<canvas id="conversionCanvas" style="display:none;"></canvas>

@section Scripts {
    <script>
        const sessionIn = document.getElementById('sessionInput');
        const deptIn    = document.getElementById('deptInput');
        const regIn     = document.getElementById('regInput');
        const preview   = document.getElementById('barcodePreview');

        function updatePreview() {
            const s = sessionIn.value || '0000';
            const d = (deptIn.value || 'XX').toUpperCase();
            const r = regIn.value || '000';
            preview.textContent = `${s}-${d}-${r}`;
        }

        [sessionIn, deptIn, regIn].forEach(el => el.addEventListener('input', updatePreview));
        updatePreview();

        function downloadResultAsPng() {
            const link = document.createElement('a');
            link.href = "data:image/png;base64,@Model.GeneratedQrCodeBase64";
            link.download = 'QR_@(Model.GeneratedBarcodeId).png';
            link.click();
        }

        function downloadResultAsJpg() {
            const imgEl  = document.getElementById('finalQrImg');
            const canvas = document.getElementById('conversionCanvas');
            canvas.width  = imgEl.naturalWidth  || 400;
            canvas.height = imgEl.naturalHeight || 400;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#FFFFFF';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.drawImage(imgEl, 0, 0);
            const link = document.createElement('a');
            link.href     = canvas.toDataURL('image/jpeg', 0.9);
            link.download = 'QR_@(Model.GeneratedBarcodeId).jpg';
            link.click();
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}

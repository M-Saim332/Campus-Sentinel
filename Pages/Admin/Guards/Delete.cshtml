@page
@model CampusSentinel.Pages.Admin.Guards.DeleteModel
@{
    ViewData["Title"] = "Delete Guard";
}

<div class="animate-fade-in" style="max-width: 600px; margin: 0 auto;">
    <div style="margin-bottom: 2rem;">
        <h2>Delete Security Guard</h2>
        <h3 class="text-danger">Are you sure you want to delete this guard?</h3>
    </div>

    <div class="glass-card">
        <dl class="row">
            <dt class="col-sm-3">Username</dt>
            <dd class="col-sm-9">@Model.Guard.Username</dd>
            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.Guard.CreatedAt.ToString("g")</dd>
        </dl>

        <form method="post" style="margin-top: 2rem;">
            <input type="hidden" asp-for="Guard.Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-page="./Index" style="margin-left: 1rem;">Back to List</a>
        </form>
    </div>
</div>

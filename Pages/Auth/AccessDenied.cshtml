@page
@model CampusSentinel.Pages.Auth.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    // We can use a minimal layout or the standard one
}

<div class="cs-animate" style="max-width: 600px; margin: 4rem auto; text-align: center;">
    <div style="width: 80px; height: 80px; background: var(--cs-danger-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
        <i class="ti ti-shield-lock" style="font-size: 2.5rem; color: var(--cs-danger);"></i>
    </div>
    
    <h1 style="font-size: 2rem; font-weight: 700; color: var(--cs-text-primary); margin: 0 0 0.5rem;">
        Access Denied
    </h1>
    
    <p style="color: var(--cs-text-secondary); margin: 0 0 2rem; font-size: 1.1rem;">
        You do not have permission to access this page. If you believe this is an error, please contact your administrator.
    </p>

    <a asp-page="/Index" class="cs-btn cs-btn-primary" style="padding: 10px 24px; font-size: 1rem;">
        <i class="ti ti-home"></i> Return to Home
    </a>
</div>
